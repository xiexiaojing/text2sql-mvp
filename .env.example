# Copy to .env.local and fill in your own values.
# NEVER commit .env.local — it is gitignored.

# Tenant scope injected into SQL at runtime (API default if unset)
TEXT2SQL_DEFAULT_DOMAIN_ID=demo-tenant-1

# dry_run: plan SQL only | live: execute against MySQL when credentials exist
TEXT2SQL_EXECUTION_MODE=dry_run

# direct_mysql | mysql_mcp
TEXT2SQL_EXECUTOR_BACKEND=direct_mysql

# Allow returning sensitive columns such as payer_mobile
TEXT2SQL_ALLOW_SENSITIVE_FIELDS=false

# --- MySQL (only needed for live mode) ---
TEXT2SQL_MYSQL_HOST=
TEXT2SQL_MYSQL_PORT=3306
TEXT2SQL_MYSQL_DATABASE=
TEXT2SQL_MYSQL_USER=
TEXT2SQL_MYSQL_PASSWORD=
TEXT2SQL_MYSQL_SSL_DISABLED=true

# --- LLM fallback (optional; leave empty to use template-only mode) ---
TEXT2SQL_LLM_BASE_URL=
TEXT2SQL_LLM_API_KEY=
TEXT2SQL_LLM_MODEL=
TEXT2SQL_LLM_TRANSPORT=openai
TEXT2SQL_LLM_POLICY=auto
# auto | always | never — when to call LLM for slot extraction inside semantic planning
TEXT2SQL_LLM_SLOT_POLICY=auto

# Audit SQLite path (local only)
TEXT2SQL_AUDIT_DB=data/audit.sqlite3

# --- Field encryption (optional; payment demo uses key distinct from community) ---
TEXT2SQL_ENCRYPTION_ENABLED=false
TEXT2SQL_ENCRYPTION_KEY=小胖蟹
TEXT2SQL_ENCRYPTION_TYPE=sm4

# --- Intent vector / embeddings (optional) ---
TEXT2SQL_INTENT_VECTOR_ENABLED=false
TEXT2SQL_INTENT_VECTOR_BASE_URL=
TEXT2SQL_INTENT_VECTOR_API_KEY=
TEXT2SQL_INTENT_VECTOR_MODEL=
